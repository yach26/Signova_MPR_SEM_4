# =============================================================================
# SignLang AI – .gitignore
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# SECRETS & ENVIRONMENT
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example          # keep the example template
!.env.local.example    # keep any frontend example template
frontend/.env.local    # local Next.js secrets

# ──────────────────────────────────────────────────────────────────────────────
# LARGE / BINARY MODEL FILES  (use Git LFS or share via cloud storage)
# ──────────────────────────────────────────────────────────────────────────────
# Trained model weights – too large for GitHub (>100 MB limit)
*.pth
*.pth.zip
*.pt
*.h5
*.ckpt
*.safetensors
*.onnx
*.bin
*.pb
*.tflite

# MediaPipe task bundles (≈7 MB – borderline; excluded to keep clone fast)
*.task

# Generated / cached model artefacts produced at runtime
backend/.model_cache/

# ──────────────────────────────────────────────────────────────────────────────
# PYTHON  (backend + inference scripts)
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / pyright
.mypy_cache/
.pyright/
pyrightconfig.json

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE  (runtime SQLite files – not for version control)
# ──────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ──────────────────────────────────────────────────────────────────────────────
# NODE / NEXT.JS  (frontend)
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/.next/cache/

# Next.js build output
frontend/out/
frontend/build/

# pnpm
pnpm-lock.yaml           # lock files become stale; use npm install / pnpm install
# Uncomment the line below if you prefer to commit the npm lock file
# !frontend/package-lock.json

# TypeScript build info (large, regenerated on build)
*.tsbuildinfo

# ──────────────────────────────────────────────────────────────────────────────
# LOGS
# ──────────────────────────────────────────────────────────────────────────────
runtime_logs/
*.log
*.out
*.err
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────────────────────────────────────
# SCREENSHOTS & MEDIA CAPTURES  (generated at runtime)
# ──────────────────────────────────────────────────────────────────────────────
MPR_STATIC_M/screenshots/
screenshots/
captures/

# ──────────────────────────────────────────────────────────────────────────────
# OS CLUTTER
# ──────────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ──────────────────────────────────────────────────────────────────────────────
# EDITORS / IDEs
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
.vs/

# ──────────────────────────────────────────────────────────────────────────────
# MISC
# ──────────────────────────────────────────────────────────────────────────────
# Temporary files created during model flattening / repair
*.tmp
*.download
*.bak
